[Unit]
Description=Java 21 (Eclipse Temurin) portable development environment

[Container]
Image=docker.io/library/eclipse-temurin:21-jdk
ContainerName=lab-java
Network=lab-net.network
IP=__LAB_JAVA_IP__
PublishPort=8082:8080
Volume=%h/Projects:/workspace:Z
Exec=sleep infinity

[Service]
Restart=always
SuccessExitStatus=0 143

[Install]
WantedBy=default.target
